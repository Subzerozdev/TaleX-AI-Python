# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Rate Limiting
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_SEARCH=30/minute

# Milvus (dùng "milvus" khi chạy Docker Compose, "localhost" khi chạy local)
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Fingerprint
FINGERPRINT_FPS=1
FINGERPRINT_SIMILARITY_THRESHOLD=0.85
FINGERPRINT_MIN_MATCH_SECONDS=5

# Kafka (Aiven) - Content Pipeline
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_CA_CERT=
KAFKA_ACCESS_CERT=
KAFKA_ACCESS_KEY=
KAFKA_SSL_CAFILE=/app/certs/ca.pem
KAFKA_SSL_CERTFILE=/app/certs/service.cert
KAFKA_SSL_KEYFILE=/app/certs/service.key
KAFKA_CONSUMER_GROUP=python-content-pipeline-group

# AWS S3 + Rekognition
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=talex-media-139139347126

# Rekognition Content Moderation
REKOGNITION_CONFIDENCE_THRESHOLD=80.0
REKOGNITION_MAX_FRAMES=30
MODERATION_FRAME_INTERVAL=2.0
