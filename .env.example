# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Rate Limiting
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_SEARCH=30/minute

# Milvus (dùng "milvus" khi chạy Docker Compose, "localhost" khi chạy local)
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Fingerprint
FINGERPRINT_FPS=1
FINGERPRINT_SIMILARITY_THRESHOLD=0.85
FINGERPRINT_MIN_MATCH_SECONDS=5
